{
  "permissions": {
    "defaultMode": "default",
    "deny": [
      "Bash(bash:*)",
      "Bash(sh:*)",
      "Bash(env:*)",
      "Bash(eval:*)",
      "Bash(xargs:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(nc:*)",
      "Bash(ncat:*)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "WebFetch"
    ],
    "allow": [
      "Bash(npm run test:*)",
      "Bash(npm run build:*)",
      "Read(./src/**)"
    ]
  }
}
